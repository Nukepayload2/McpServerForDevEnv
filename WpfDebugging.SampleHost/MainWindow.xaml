<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WPF Debug SampleHost"
        Height="500" Width="600"
        WindowStartupLocation="CenterScreen">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16" x:Name="RootPanel">

            <Label Content="WPF 调试 SampleHost（被控端示例）"
                   FontWeight="Bold" FontSize="14"
                   x:Name="HeaderLabel"
                   Margin="0,0,0,12"/>

            <!-- TextBox：fill / evaluate 操作目标 -->
            <Label Content="TextBox（fill/evaluate 目标）" Margin="0,0,0,4"/>
            <TextBox x:Name="InputTextBox"
                     Text="初始文本"
                     Margin="0,0,0,12"/>

            <!-- MultiLine TextBox -->
            <Label Content="多行 TextBox" Margin="0,0,0,4"/>
            <TextBox x:Name="MultilineTextBox"
                     Text="第一行&#13;第二行"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="60"
                     Margin="0,0,0,12"/>

            <!-- Button：click 目标 -->
            <Button x:Name="ClickButton"
                    Content="点我（click 目标）"
                    Padding="12,4"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,12"/>

            <!-- CheckBox：fill 目标（布尔值） -->
            <CheckBox x:Name="OptionCheckBox"
                      Content="选项 CheckBox（fill 目标）"
                      IsChecked="True"
                      Margin="0,0,0,8"/>

            <!-- 多个 CheckBox -->
            <CheckBox x:Name="OptionCheckBox2"
                      Content="第二个 CheckBox"
                      Margin="0,0,0,12"/>

            <!-- RadioButton：fill 目标 -->
            <Label Content="RadioButton 组（fill 目标）" Margin="0,0,0,4"/>
            <RadioButton x:Name="RadioA"
                         Content="选项 A"
                         GroupName="Group1"
                         IsChecked="True"
                         Margin="0,0,0,4"/>
            <RadioButton x:Name="RadioB"
                         Content="选项 B"
                         GroupName="Group1"
                         Margin="0,0,0,12"/>

            <!-- ComboBox：fill 目标 -->
            <Label Content="ComboBox（fill 目标）" Margin="0,0,0,4"/>
            <ComboBox x:Name="ChoiceComboBox"
                      SelectedIndex="0"
                      Margin="0,0,0,12">
                <ComboBoxItem Content="第一项"/>
                <ComboBoxItem Content="第二项"/>
                <ComboBoxItem Content="第三项"/>
            </ComboBox>

            <!-- Slider：evaluate 读写目标 -->
            <Label Content="Slider（evaluate 读写目标）" Margin="0,0,0,4"/>
            <Slider x:Name="ValueSlider"
                    Minimum="0" Maximum="100" Value="50"
                    TickFrequency="10" TickPlacement="BottomRight"
                    Margin="0,0,0,12"/>

            <!-- ListBox：snapshot 目标（多子项） -->
            <Label Content="ListBox（snapshot 目标）" Margin="0,0,0,4"/>
            <ListBox x:Name="ItemList"
                     MinHeight="80"
                     Margin="0,0,0,12">
                <ListBoxItem Content="项目一"/>
                <ListBoxItem Content="项目二"/>
                <ListBoxItem Content="项目三"/>
            </ListBox>

            <!-- 状态 Label：脚本操作后回显 -->
            <Label Content="状态回显" Margin="0,0,0,4"/>
            <TextBlock x:Name="StatusTextBlock"
                       Text="就绪"
                       Padding="8,4"
                       Background="#FFF0F0F0"
                       Margin="0,0,0,12"/>

        </StackPanel>
    </ScrollViewer>
</Window>
