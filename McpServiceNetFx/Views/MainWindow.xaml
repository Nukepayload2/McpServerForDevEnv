<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:McpServiceNetFx"
        mc:Ignorable="d" Background="#F7F7F7"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:core="clr-namespace:McpServiceNetFx;assembly=McpServiceNetFx.Core"
        xmlns:res="clr-namespace:McpServiceNetFx.My.Resources;assembly=McpServiceNetFx.Core"
        xmlns:conv="clr-namespace:McpServiceNetFx.Converters"
        Title="{x:Static res:Resources.AppTitle}" Height="600" Width="900" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <conv:PermissionLevelConverter x:Key="PermissionLevelConverter"/>
        <conv:FileAccessTypeConverter x:Key="FileAccessTypeConverter"/>
        <conv:PermissionLevelsConverter x:Key="PermissionLevelsConverter"/>

        <!-- Watermark TextBox Style for DataGrid Pattern Column -->
        <Style x:Key="WatermarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <TextBlock x:Name="WatermarkText"
                                       Text="{x:Static res:Resources.PathPolicy_Pattern_Placeholder}"
                                       Foreground="Gray"
                                       Margin="4,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="0"
                                          VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Text" Value=""/>
                                    <Condition Property="IsKeyboardFocusWithin" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="WatermarkText" Property="Visibility" Value="Visible"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <TabControl x:Name="TabControlMain">
            <TabItem Header="{x:Static res:Resources.TabServiceManagement}">
                <Grid>
                    <Grid.RowDefinitions>
                        <!-- Row0：服务启停按钮（一行） -->
                        <RowDefinition Height="Auto"/>
                        <!-- Row1：主体，按被控端类型 / 服务设置分子 tab（VS 实例 / WPF 程序 / 服务设置） -->
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Row0：仅放启停服务按钮，避免占用过多纵向空间 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="BtnStartService" Content="{x:Static res:Resources.ButtonStartService}" Width="100"/>
                        <Button x:Name="BtnStopService" Content="{x:Static res:Resources.ButtonStopService}" Width="100" Margin="10,0,0,0" IsEnabled="False"/>
                    </StackPanel>

                    <!-- 被控端实例分子 tab：VS 实例 + WPF 程序 + 服务设置 -->
                    <TabControl x:Name="TabInstances" Grid.Row="1" Margin="0,8,0,0">

                        <!-- 子 tab：Visual Studio 实例 -->
                        <TabItem Header="{x:Static res:Resources.TabVsInstances}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBox x:Name="TxtSearch" Width="300" Margin="0,0,10,0"/>
                                    <Button x:Name="BtnRefresh" Content="{x:Static res:Resources.ButtonRefresh}" Width="80"/>
                                </StackPanel>

                                <ui:DataGrid x:Name="DgVsInstances" Grid.Row="1" AutoGenerateColumns="False"
                                          IsReadOnly="True" SelectionMode="Single" CanUserAddRows="False"
                                          GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                                    <ui:DataGrid.Columns>
                                        <DataGridTextColumn Header="{x:Static res:Resources.HeaderWindowCaption}" Binding="{Binding Caption}" Width="*" FontSize="12"/>
                                        <DataGridTextColumn Header="{x:Static res:Resources.HeaderSolutionPath}" Binding="{Binding SolutionPath}" Width="2*" FontSize="12"/>
                                        <DataGridTextColumn Header="{x:Static res:Resources.HeaderVersion}" Binding="{Binding Version}"/>
                                        <DataGridTextColumn Header="{x:Static res:Resources.HeaderProcessId}" Binding="{Binding ProcessId}"/>
                                    </ui:DataGrid.Columns>
                                </ui:DataGrid>
                            </Grid>
                        </TabItem>

                        <!-- 子 tab：WPF 调试被控端 -->
                        <TabItem Header="{x:Static res:Resources.TabWpfTargets}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 刷新候选列表（枚举系统 named pipe，不连接） + 连接/断开 -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button x:Name="BtnRefreshWpfTargets" Content="{x:Static res:Resources.ButtonRefreshWpfTargets}" Width="110" Margin="0,0,10,0"/>
                                    <Button x:Name="BtnWpfDebugConnect" Content="连接" Width="80" Margin="0,0,10,0"/>
                                    <Button x:Name="BtnWpfDebugDisconnect" Content="断开" Width="80" Margin="0,0,10,0" IsEnabled="False"/>
                                </StackPanel>

                                <!-- 候选被控端列表：选中一项后点"连接" -->
                                <ui:DataGrid x:Name="DgWpfDebugTargets" Grid.Row="1" AutoGenerateColumns="False"
                                          IsReadOnly="True" SelectionMode="Single" CanUserAddRows="False"
                                          GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                                    <ui:DataGrid.Columns>
                                        <DataGridTextColumn Header="{x:Static res:Resources.HeaderWpfWindow}" Binding="{Binding MainWindowTitle}" Width="*"/>
                                        <DataGridTextColumn Header="{x:Static res:Resources.HeaderWpfPath}" Binding="{Binding ProcessPath}" Width="2*"/>
                                        <DataGridTextColumn Header="{x:Static res:Resources.HeaderWpfPid}" Binding="{Binding Pid}"/>
                                    </ui:DataGrid.Columns>
                                </ui:DataGrid>

                                <!-- 当前连接状态（Pid/Title 来自握手；ProcessPath 可选） -->
                                <GroupBox Grid.Row="2" Header="被控端连接" Margin="0,8,0,0">
                                    <Grid Margin="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Label Grid.Row="0" Grid.Column="0" Content="状态" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtWpfDebugStatus" Grid.Row="0" Grid.Column="1"
                                                   Text="未连接" VerticalAlignment="Center" Margin="10,0,0,0"/>

                                        <Label Grid.Row="1" Grid.Column="0" Content="PID" VerticalAlignment="Center" Margin="0,8,0,0"/>
                                        <TextBlock x:Name="TxtWpfDebugPid" Grid.Row="1" Grid.Column="1"
                                                   Text="-" VerticalAlignment="Center" Margin="10,8,0,0"/>

                                        <Label Grid.Row="2" Grid.Column="0" Content="主窗口" VerticalAlignment="Center" Margin="0,8,0,0"/>
                                        <TextBlock x:Name="TxtWpfDebugTitle" Grid.Row="2" Grid.Column="1"
                                                   Text="-" VerticalAlignment="Center" Margin="10,8,0,0" TextWrapping="Wrap"/>
                                    </Grid>
                                </GroupBox>
                            </Grid>
                        </TabItem>

                        <!-- 子 tab：服务设置（端口 / 状态 / 客户端配置），从原 GroupServiceSettings 迁入 -->
                        <TabItem Header="{x:Static res:Resources.TabServiceSettings}">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="{x:Static res:Resources.LabelInstance}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtSelectedInstance" Grid.Row="0" Grid.Column="1"
                                           Text="{x:Static res:Resources.TextSelectInstance}" VerticalAlignment="Center" Margin="10,0,0,0"/>

                                <Label Grid.Row="1" Grid.Column="0" Content="{x:Static res:Resources.LabelPort}" VerticalAlignment="Center"
                                        Margin="0,10,0,0"/>
                                <TextBox x:Name="TxtPort" Grid.Row="1" Grid.Column="1"
                                         Margin="10,10,10,0" Text="38080"/>

                                <Label Grid.Row="2" Grid.Column="0" Content="{x:Static res:Resources.LabelStatus}" VerticalAlignment="Center"
                                        Margin="0,10,0,0"/>
                                <TextBlock x:Name="TxtServiceStatus" Grid.Row="2" Grid.Column="1"
                                           Text="{x:Static res:Resources.TextServiceNotStarted}" VerticalAlignment="Center" Margin="10,10,0,0"/>

                                <Label Grid.Row="3" Grid.Column="0" Content="{x:Static res:Resources.LabelClientConfig}" VerticalAlignment="Center"
                                        Margin="0,10,0,0"/>
                                <!-- 客户端配置 Visibility=Collapsed 保持，由 code-behind 控制 -->
                                <Grid Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,0">
                                    <TabControl x:Name="TabClientConfig" Visibility="Collapsed">
                                        <TabItem Header="{x:Static res:Resources.TabJsonConfig}">
                                            <TextBox x:Name="TxtJsonConfig" Margin="5"
                                                     IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                                                     HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap"
                                                     FontFamily="Consolas" FontSize="11"
                                                     Text="{x:Static res:Resources.TextJsonConfigHint}"/>
                                        </TabItem>
                                        <TabItem Header="{x:Static res:Resources.TabClaudeConfig}">
                                            <TextBox x:Name="TxtClaudeConfig" Margin="5"
                                                     IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                                                     HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap"
                                                     FontFamily="Consolas" FontSize="11"
                                                     Text="{x:Static res:Resources.TextClaudeConfigHint}"/>
                                        </TabItem>
                                    </TabControl>
                                </Grid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>

            <!-- MCP 功能授权选项卡 -->
            <TabItem Header="{x:Static res:Resources.TabMcpPermissions}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 内部 TabControl 分隔功能权限和文件权限 -->
                    <TabControl x:Name="TabPermissionTypes" Grid.Row="0">
                        <!-- 功能权限 Tab -->
                        <TabItem Header="{x:Static res:Resources.PermissionType_Function}">
                            <Grid Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button x:Name="BtnAllowAll" Content="{x:Static res:Resources.ButtonAllowAll}" Width="100"
                                            Margin="0,0,10,0"/>
                                    <Button x:Name="BtnAskAll" Content="{x:Static res:Resources.ButtonAskAll}" Width="100"
                                            Margin="0,0,10,0"/>
                                </StackPanel>

                                <ui:DataGrid x:Name="DgPermissions" Grid.Row="1" AutoGenerateColumns="False"
                                          CanUserAddRows="False" GridLinesVisibility="Horizontal"
                                          HeadersVisibility="Column">
                                    <ui:DataGrid.Columns>
                                        <DataGridTextColumn Header="{x:Static res:Resources.PathPolicy_Column_FunctionName}" Binding="{Binding FeatureName}" Width="*"/>
                                        <DataGridTextColumn Header="{x:Static res:Resources.PathPolicy_Column_Description}" Binding="{Binding Description}" Width="2*"/>
                                        <DataGridTemplateColumn Header="{x:Static res:Resources.PathPolicy_Column_Permission}" Width="140">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox>
                                                        <ComboBox.ItemsSource>
                                                            <MultiBinding Converter="{StaticResource PermissionLevelsConverter}">
                                                                <Binding/>
                                                                <Binding Path="IsFileTool"/>
                                                            </MultiBinding>
                                                        </ComboBox.ItemsSource>
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Converter={StaticResource PermissionLevelConverter}}"/>
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                        <ComboBox.SelectedItem>
                                                            <Binding Path="Permission" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged"/>
                                                        </ComboBox.SelectedItem>
                                                    </ComboBox>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </ui:DataGrid.Columns>
                                </ui:DataGrid>
                            </Grid>
                        </TabItem>

                        <!-- 文件权限 Tab -->
                        <TabItem Header="{x:Static res:Resources.PermissionType_File}">
                            <Grid Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TabControl x:Name="TabPathPolicies" Grid.Row="0">
                                    <TabItem Header="{x:Static res:Resources.PathPolicy_AllowList}">
                                        <Grid>
                                            <ui:DataGrid x:Name="DgAllowPolicies" AutoGenerateColumns="False"
                                                      CanUserAddRows="False" GridLinesVisibility="Horizontal"
                                                      HeadersVisibility="Column" >
                                                <ui:DataGrid.Columns>
                                                    <DataGridTextColumn Header="{x:Static res:Resources.PathPolicy_Column_Pattern}" Binding="{Binding Pattern}" Width="2*">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                                <Setter Property="Margin" Value="4,0,0,0"/>
                                                            </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                        <DataGridTextColumn.EditingElementStyle>
                                                            <Style BasedOn="{StaticResource WatermarkTextBoxStyle}" TargetType="TextBox">
                                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                                <Setter Property="Margin" Value="0"/>
                                                            </Style>
                                                        </DataGridTextColumn.EditingElementStyle>
                                                    </DataGridTextColumn>
                                                    <DataGridTemplateColumn Header="{x:Static res:Resources.PathPolicy_Column_AccessType}" Width="140">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <ComboBox ItemsSource="{x:Static core:FileAccessTypes.Value}"
                                                                  SelectedItem="{Binding FileAccess, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  IsEditable="False"
                                                                  Background="Transparent"
                                                                  BorderThickness="0">
                                                                    <ComboBox.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding Converter={StaticResource FileAccessTypeConverter}}"/>
                                                                        </DataTemplate>
                                                                    </ComboBox.ItemTemplate>
                                                                </ComboBox>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </ui:DataGrid.Columns>
                                            </ui:DataGrid>
                                        </Grid>
                                    </TabItem>
                                    <TabItem Header="{x:Static res:Resources.PathPolicy_DenyList}">
                                        <Grid>
                                            <ui:DataGrid x:Name="DgDenyPolicies" AutoGenerateColumns="False"
                                                      CanUserAddRows="False" GridLinesVisibility="Horizontal"
                                                      HeadersVisibility="Column">
                                                <ui:DataGrid.Columns>
                                                    <DataGridTextColumn Header="{x:Static res:Resources.PathPolicy_Column_Pattern}" Binding="{Binding Pattern}" Width="2*">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                                <Setter Property="Margin" Value="4,0,0,0"/>
                                                            </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                        <DataGridTextColumn.EditingElementStyle>
                                                            <Style BasedOn="{StaticResource WatermarkTextBoxStyle}" TargetType="TextBox">
                                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                                <Setter Property="Margin" Value="0"/>
                                                            </Style>
                                                        </DataGridTextColumn.EditingElementStyle>
                                                    </DataGridTextColumn>
                                                    <DataGridTemplateColumn Header="{x:Static res:Resources.PathPolicy_Column_AccessType}" Width="140">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <ComboBox ItemsSource="{x:Static core:FileAccessTypes.Value}"
                                                                  SelectedItem="{Binding FileAccess, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  IsEditable="False"
                                                                  Background="Transparent"
                                                                  BorderThickness="0">
                                                                    <ComboBox.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding Converter={StaticResource FileAccessTypeConverter}}"/>
                                                                        </DataTemplate>
                                                                    </ComboBox.ItemTemplate>
                                                                </ComboBox>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </ui:DataGrid.Columns>
                                            </ui:DataGrid>
                                        </Grid>
                                    </TabItem>
                                </TabControl>

                                <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                    <TextBlock Text="{x:Static res:Resources.PathPolicy_Hint_DenyPriority}" TextWrapping="Wrap" Margin="5,2"/>
                                    <TextBlock Text="{x:Static res:Resources.PathPolicy_Hint_Unmatched}" TextWrapping="Wrap" Margin="5,2"/>
                                    <StackPanel Orientation="Horizontal" Margin="5,2">
                                        <TextBlock TextWrapping="Wrap">
                                            <Run Text="{x:Static res:Resources.PathPolicy_Hint_WildcardPrefix}"/>
                                            <Hyperlink RequestNavigate="OnLearnMoreClick" NavigateUri="">
                                                <Run Text="{x:Static res:Resources.PathPolicy_Hint_WildcardLink}"/>
                                            </Hyperlink>
                                            <Run Text="{x:Static res:Resources.PathPolicy_Hint_WildcardSuffix}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button x:Name="BtnAddPolicy" Content="{x:Static res:Resources.PathPolicy_Button_AddPolicy}" Width="100"
                                            Margin="0,0,10,0" Click="BtnAddPolicy_Click"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>
                    </TabControl>

                    <!-- 保存和重新加载按钮 -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,10">
                        <Button x:Name="BtnSavePermissions" Content="{x:Static res:Resources.ButtonSaveConfigAndPolicies}" Width="140"
                                Margin="0,0,10,0"/>
                        <Button x:Name="BtnReloadPermissions" Content="{x:Static res:Resources.ButtonReload}" Width="100"/>
                    </StackPanel>
                </Grid>
            </TabItem>

    
            <!-- 日志选项卡 -->
            <TabItem Header="{x:Static res:Resources.TabLogs}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,8">
                        <Button x:Name="BtnClearLogs" Content="{x:Static res:Resources.ButtonClearLogs}" Width="100"
                                Margin="0,0,10,0"/>
                        <Button x:Name="BtnExportLogs" Content="{x:Static res:Resources.ButtonExportLogs}" Width="100"/>
                    </StackPanel>

                    <DataGrid x:Name="DgLogs" Grid.Row="1" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False" GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              EnableRowVirtualization="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{x:Static res:Resources.HeaderTime}" Binding="{Binding Timestamp}" Width="150"/>
                            <DataGridTextColumn Header="{x:Static res:Resources.HeaderOperation}" Binding="{Binding Operation}" Width="*"/>
                            <DataGridTextColumn Header="{x:Static res:Resources.HeaderResult}" Binding="{Binding Result}" Width="100"/>
                            <DataGridTextColumn Header="{x:Static res:Resources.HeaderDetails}" Binding="{Binding Details}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="{x:Static res:Resources.TabAbout}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="28" Margin="4" Text="{x:Static res:Resources.TextAboutTitle}"/>
                    <TextBlock Grid.Row="1" FontSize="14" Margin="4" TextWrapping="Wrap" Text="{x:Static res:Resources.TextAboutContent}"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
